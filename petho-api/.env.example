# =============================================
# Petho API - Variables de entorno
# =============================================
# Copia a .env y completa los valores

# Base de datos PostgreSQL
# Para Supabase usar pooler (ej: aws-0-us-west-2.pooler.supabase.com)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=pethoV8
# Supabase requiere SSL: DB_SSL=true
DB_SSL=false

# API
PORT=3001

# Firebase Admin SDK (requerido para autenticación)
# Opción A: ruta al archivo JSON (más simple, evita escapar la clave en .env)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-credentials.json

# Opción B: variables individuales (desde Firebase Console > Service Accounts > Generate new private key)
# FIREBASE_PROJECT_ID=tu-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# CORS - varios orígenes separados por coma
# Desarrollo: http://localhost:5173
# Producción: https://dashboard-petho.web.app o tu URL de Firebase Hosting
CORS_ORIGIN=http://localhost:5173

# Entorno
NODE_ENV=development

# Admin inicial (solo si no existe)
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password
